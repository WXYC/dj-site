    "@mui/joy": "^5.0.0-beta.51",
    "@mui/material": "^6.4.0",
    "@opennextjs/cloudflare": "^1.10.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@uidotdev/usehooks": "^2.4.1",
    "@wxyc/shared": "^1.11.0",
    "better-auth": "^1.6.20",
    "cookie": "^1.0.2",
    "jose": "^6.2.3",
    "jwt-decode": "^4.0.0",
    "motion": "^12.40.0",
    "next": "^16.1.1",
    "posthog-js": "^1.386.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-fast-marquee": "^1.6.5",
    "react-redux": "^9.3.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "webcrypt-session": "^0.5.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.5.0",
