    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.18",
    "bats": "^1.11.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "pg": "^8.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18",
    "wrangler": "^4.103.0"
  },
